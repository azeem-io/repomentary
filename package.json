{
  "name": "repomentary",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @repomentary/web dev",
    "build": "pnpm --filter @repomentary/web build",
    "typecheck": "pnpm --recursive typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "preview": "pnpm --filter @repomentary/web preview",
    "deploy": "pnpm --filter @repomentary/web deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "typescript": "~5.9.3"
  }
}
